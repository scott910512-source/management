// Travel Korea Tracker - Prisma schema
// 초기 DB는 SQLite. PostgreSQL 전환 시 provider + DATABASE_URL 만 변경하면 됩니다.
// (cuid/String 기반 PK, enum 대신 String 사용으로 DB 호환성 확보)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// 사용자
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  /// "ADMIN" | "USER"
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visits    Visit[]
  wishlists Wishlist[]
  badges    UserBadge[]

  @@index([role])
}

/// 시도 (서울특별시, 경상북도 ...)
model Province {
  id      String   @id @default(cuid())
  name    String   @unique
  code    String   @unique
  order   Int      @default(0)
  regions Region[]
}

/// 시군구 (강남구, 안동시 ...)
model Region {
  id         String  @id @default(cuid())
  provinceId String
  province   Province @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  /// 시도명 (비정규화 - 조회 편의)
  provinceName String
  /// 시군구명
  district   String
  order      Int     @default(0)

  visits     Visit[]
  wishlists  Wishlist[]

  @@unique([provinceId, district])
  @@index([provinceName])
}

/// 방문 기록 (사용자 x 지역)
model Visit {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  regionId  String
  region    Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  /// "VISITED" | "PLANNED" | "UNVISITED"
  status    String   @default("VISITED")
  visitDate DateTime?
  memo      String?
  /// "PUBLIC" | "PRIVATE" | "GROUP"
  visibility String  @default("PRIVATE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  photos    Photo[]
  shares    VisitShare[]

  @@unique([userId, regionId])
  @@index([userId])
  @@index([status])
}

/// 그룹공유 대상 (visibility = GROUP 일 때)
model VisitShare {
  id      String @id @default(cuid())
  visitId String
  visit   Visit  @relation(fields: [visitId], references: [id], onDelete: Cascade)
  userId  String

  @@unique([visitId, userId])
}

/// 사진 (방문당 최대 20장 - 애플리케이션에서 강제)
model Photo {
  id        String   @id @default(cuid())
  visitId   String
  visit     Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  imagePath String
  caption   String?
  createdAt DateTime @default(now())

  @@index([visitId])
}

/// 버킷리스트
model Wishlist {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  regionId String
  region   Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, regionId])
  @@index([userId])
}

/// 배지 정의
model Badge {
  id          String @id @default(cuid())
  /// 고유 코드 (예: SEOUL_COMPLETE)
  key         String @unique
  name        String
  description String
  icon        String @default("🏅")
  users       UserBadge[]
}

/// 사용자가 획득한 배지
model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt  DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
}
